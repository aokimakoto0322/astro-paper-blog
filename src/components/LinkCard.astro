---
// src/components/LinkCard.astro
import ogs from 'open-graph-scraper';

interface Props {
  url: string;
}

const { url } = Astro.props;

let title = '';
let description = '';
let image = '';
let hostname = '';

try {
  const urlObj = new URL(url);
  hostname = urlObj.hostname;

  // 遷移先のURLの情報を自動で取得（タイムアウト設定を追加してビルド停止を防止）
  const { result } = await ogs({ 
    url: url,
    timeout: 5000 
  });

  title = result.ogTitle || result.twitterTitle || '無題のリンク';
  description = result.ogDescription || result.twitterDescription || '';
  image = result.ogImage?.[0]?.url || result.twitterImage?.[0]?.url || '';
} catch (error) {
  console.error(`[LinkCard] データの取得に失敗しました: ${url}`, error);
  title = url;
}
---

<a href={url} target="_blank" rel="noopener noreferrer" class="link-card">
  {image && <img src={image} alt="" role="presentation" class="card-image" loading="lazy" width="150" height="100" />}
  <div class="card-content">
    <span class="card-title">{title}</span>
    {description && <p class="card-description">{description}</p>}
    <span class="card-url">{hostname || url}</span>
  </div>
</a>

<style>
  .link-card {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border, #dae2e7);
    border-radius: 0.5rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    margin: 1.5rem 0;
    background-color: var(--color-card-bg, rgba(255, 255, 255, 0.05));
    transition: background-color 0.2s ease;
  }
  .link-card:hover {
    background-color: var(--color-card-hover, rgba(255, 255, 255, 0.1));
  }
  .card-image {
    width: 150px;
    height: 100px;
    object-fit: cover;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border, #dae2e7);
  }
  .card-content {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    overflow: hidden;
  }
  .card-title {
    font-weight: bold;
    font-size: 1.1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-description {
    font-size: 0.9rem;
    opacity: 0.8;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .card-url {
    font-size: 0.8rem;
    opacity: 0.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
