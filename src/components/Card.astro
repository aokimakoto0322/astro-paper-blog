---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage, ...props } = data;
---

<li
  class="border-border/70 hover:bg-muted/30 my-3 overflow-hidden rounded-lg border transition-colors"
>
  <a
    href={getPostUrl(id, filePath, Astro.currentLocale)}
    class="group block h-full focus-visible:outline-none"
  >
    {
      ogImage && (
        <img
          src={typeof ogImage === "string" ? ogImage : ogImage.src}
          alt={title}
          class="h-44 w-full object-cover sm:h-52"
          loading="lazy"
          decoding="async"
        />
      )
    }
    <div class="p-4">
      <Heading
        transition:name={slugifyStr(title.replaceAll(".", "-"))}
        class="text-foreground group-hover:text-accent text-base font-semibold sm:text-lg"
      >
        {title}
      </Heading>
      <Datetime {...props} />
      <p class="text-muted-foreground mt-1 text-sm sm:text-base">
        {description}
      </p>
    </div>
  </a>
</li>
