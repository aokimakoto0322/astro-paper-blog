---
import { getCollection } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

interface Props {
  series: string;
  currentTitle: string;
}

const { series, currentTitle } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;

const allPosts = await getCollection("posts");
const seriesPosts = allPosts
  .filter(p => !p.data.draft && p.data.series?.trim() === series.trim())
  .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
---

{
  seriesPosts.length > 1 && (
    <aside class="not-prose border-border bg-muted/30 my-8 rounded-lg border p-6">
      <p class="text-foreground mb-3 text-lg font-bold">
        【シリーズ：{series}】
      </p>
      <ol class="m-0 list-none space-y-2 p-0">
        {seriesPosts.map((post, index) => (
          <li>
            <a
              href={getPostUrl(post.id, post.filePath, locale)}
              class:list={[
                "hover:text-accent no-underline transition-colors",
                post.data.title === currentTitle
                  ? "text-foreground pointer-events-none font-bold"
                  : "text-muted-foreground",
              ]}
            >
              {index + 1}. {post.data.title}
            </a>
          </li>
        ))}
      </ol>
    </aside>
  )
}
