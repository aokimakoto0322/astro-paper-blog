---
const tsvUrl = import.meta.env.PUBLIC_SHEET_TSV_URL;

interface CommentItem {
  timestamp: string;
  articleTitle: string;
  name: string;
  content: string;
  approved: boolean;
}

let comments: CommentItem[] = [];

try {
  const response = await fetch(tsvUrl);
  if (response.ok) {
    const text = await response.text();

    // 💡 Windowsの改行コード(\r\n)による末尾のゴミを削除
    const cleanText = text.replace(/\r/g, "");
    const rows = cleanText.split("\n").map(row => row.split("\t"));

    comments = rows
      .slice(1)
      .map((row, idx) => {
        // 💡 各列のデータを取得し、前後の不要な空白を完璧にトリム
        const timestamp = row[0] ? row[0].trim() : "";
        const articleTitle = row[1] ? row[1].trim() : "";
        const name = row[2] ? row[2].trim() : "";
        const content = row[3] ? row[3].trim() : "";

        // 💡 E列（5番目）の承認フラグを厳格にチェック
        const rawApproved = row[4] ? row[4].trim().toUpperCase() : "";
        const isApproved = rawApproved === "TRUE";

        return {
          timestamp,
          articleTitle,
          name,
          content,
          approved: isApproved,
        };
      })
      // 💡 名前と記事タイトルが両方ちゃんと存在する「有効な行」だけを厳選して、空行を完全シャットアウト
      .filter(comment => comment.name && comment.articleTitle);
  }
} catch (error) {
  console.error("コメントの取得に失敗しました:", error);
}

const { currentArticleTitle } = Astro.props;
const targetTitle = currentArticleTitle?.trim() || "";

// 💡 画面に流すコメントを「タイトル一致」かつ「承認が厳格に true」の条件で絞り込み
const filteredComments = comments
  .filter(c => {
    const isTitleMatch = c.articleTitle === targetTitle;
    return isTitleMatch && c.approved === true;
  })
  .reverse();
---

<div class="comment-list-section mt-12 w-full">
  <h3 class="text-skin-accent mb-6 text-lg font-bold">
    💬 コメント一覧 ({filteredComments.length}件)
  </h3>

  {
    filteredComments.length === 0 ? (
      <p class="text-skin-base mb-6 text-sm italic opacity-70">
        まだコメントはありません。最初のコメントを書いてみませんか？🌸
      </p>
    ) : (
      <ul class="mb-8 list-none space-y-6 p-0">
        {filteredComments.map(comment => (
          <li class="border-skin-line border-b pb-4 last:border-none last:pb-0">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-skin-accent text-sm font-bold">
                {comment.name} さん
              </span>
              <span class="text-skin-base text-xs opacity-60">
                {comment.timestamp}
              </span>
            </div>
            <p class="text-skin-base text-sm leading-relaxed whitespace-pre-wrap opacity-90">
              {comment.content}
            </p>
          </li>
        ))}
      </ul>
    )
  }
</div>

<style>
  .comment-list-section {
    margin-top: 2rem;
  }
</style>
